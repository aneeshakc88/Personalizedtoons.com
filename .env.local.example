VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51T1CMV0Sfad1jQQlBkKWNQ5o1H1z8SS39iQCi0IleEW0ECErrENvcpg4noKwxpB3FQj8OoGm1JaDiASOxObcWueQ00fXHhSnMo

